{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [],
  "permission": {
    "*": "allow"
  },
  "enabled_providers": [
    "openai",
    "anthropic",
    "github-copilot",
    "deepseek",
    "antigravity-claude"
  ],
  "model": "deepseek/deepseek-v4-flash",
  "command": {
    "implement": {
      "template": "implement current plan",
      "description": "implement current plan",
      "agent": "build"
    },
    "push": {
      "template": "commit using conventional commits format `(feat|fix|chore|docs|refactor|perf|test|style|ci|build|revert): <description>` then push. If push fails due to divergence, fetch + rebase and retry push.",
      "description": "commit and push with auto rebase on failure",
      "agent": "build"
    },
    "commit": {
      "template": "commit using conventional commits format (feat|fix|chore|docs|refactor|perf|test|style|ci|build|revert): <description>",
      "description": "commit with conventional commit format",
      "agent": "build"
    },
    "pr": {
      "template": "check if a PR already exists for the current branch using `gh pr view --json url --jq .url`. If found, return its URL. If not, create one with `gh pr create --fill` and return the URL.",
      "description": "create or return existing PR",
      "agent": "build"
    }
  },
  "agent": {
    "plan": {
      "mode": "subagent",
      "model": "openai/gpt-5.5",
      "reasoningEffort": "high"
    },
    "build": {
      "model": "deepseek/deepseek-v4-flash"
    }
  },
  "provider": {
    "openai": {
      "whitelist": [
        "gpt-5.5"
      ]
    },
    "anthropic": {
      "whitelist": [
        "claude-opus-4-8",
        "claude-opus-4-7",
        "claude-sonnet-4-6"
      ]
    },
    "github-copilot": {
      "whitelist": [
        "gpt-5.5",
        "claude-sonnet-4.6",
        "claude-opus-4.6"
      ]
    },
    "deepseek": {
      "whitelist": [
        "deepseek-v4-pro",
        "deepseek-v4-flash"
      ]
    }
  }
}
