{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [],
  "permission": {
    "*": "allow"
  },
  "enabled_providers": [
    "openai",
    "anthropic",
    "github-copilot",
    "deepseek",
    "antigravity-claude"
  ],
  "model": "deepseek/deepseek-v4-flash",
  "agent": {
    "plan": {
      "mode": "subagent",
      "model": "openai/gpt-5.5",
      "reasoningEffort": "high"
    },
    "build": {
      "model": "deepseek/deepseek-v4-flash"
    }
  },
  "provider": {
    "openai": {
      "whitelist": [
        "gpt-5.5"
      ]
    },
    "anthropic": {
      "whitelist": [
        "claude-opus-4-8",
        "claude-opus-4-7",
        "claude-sonnet-4-6"
      ]
    },
    "github-copilot": {
      "whitelist": [
        "gpt-5.5",
        "claude-sonnet-4.6",
        "claude-opus-4.6"
      ]
    },
    "deepseek": {
      "whitelist": [
        "deepseek-v4-pro",
        "deepseek-v4-flash"
      ]
    }
  }
}
