{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [],
  "permission": {
    "*": "allow"
  },
  "enabled_providers": [
    "openai",
    "anthropic",
    "github-copilot",
    "deepseek",
    "antigravity-claude"
  ],
  "model": "deepseek/deepseek-v4-flash",
  "agent": {
    "plan": {
      "model": "deepseek/deepseek-v4-flash",
      "reasoningEffort": "high"
    },
    "p": {
      "mode": "subagent",
      "model": "openai/gpt-5.5",
      "reasoningEffort": "high"
    },
    "build": {
      "model": "deepseek/deepseek-v4-flash",
      "reasoningEffort": "high"
    },
    "general": {
      "model": "deepseek/deepseek-v4-flash",
      "reasoningEffort": "high"
    },
    "explore": {
      "model": "deepseek/deepseek-v4-flash",
      "reasoningEffort": "high"
    },
    "compaction": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "high"
    },
    "title": {
      "model": "deepseek/deepseek-v4-flash",
      "reasoningEffort": "low"
    },
    "summary": {
      "model": "deepseek/deepseek-v4-flash",
      "reasoningEffort": "low"
    }
  },
  "provider": {
    "openai": {
      "whitelist": [
        "gpt-5.5"
      ],
      "options": {
        "apiKey": "sops:sub2api_my_openai_api_key",
        "baseURL": "sops:sub2api_my_openai_base_url"
      }
    },
    "anthropic": {
      "whitelist": [
        "claude-opus-4-8",
        "claude-opus-4-7",
        "claude-sonnet-4-6"
      ],
      "options": {
        "apiKey": "sops:sub2api_my_anthropic_api_key",
        "baseURL": "sops:sub2api_my_anthropic_base_url"
      }
    },
    "github-copilot": {
      "whitelist": [
        "gpt-5.5",
        "claude-sonnet-4.6",
        "claude-opus-4.6"
      ]
    },
    "deepseek": {
      "whitelist": [
        "deepseek-v4-pro",
        "deepseek-v4-flash"
      ],
      "options": {
        "apiKey": "sops:sub2api_my_deepseek_api_key",
        "baseURL": "sops:sub2api_my_deepseek_base_url"
      }
    }
  }
}
