+  private async emitUsageUpdate(): Promise<void> {
+    try {
+      const stats = (await this.proc.getSessionStats()) as any
+      const contextUsage = stats?.contextUsage
+      const used = contextUsage?.tokens
+      const size = contextUsage?.contextWindow
+
+      if (typeof used !== 'number' || !Number.isFinite(used)) return
+      if (typeof size !== 'number' || !Number.isFinite(size) || size <= 0) return
+
+      const amount = stats?.cost
+      this.emit({
+        sessionUpdate: 'usage_update',
+        used,
+        size,
+        cost:
+          typeof amount === 'number' && Number.isFinite(amount)
+            ? { amount, currency: 'USD' }
+            : undefined
+      })
+    } catch {
+      // Best-effort only: usage updates should never break prompt completion.
+    }
+  }
+
   private startTurn(t: QueuedTurn): void {
     this.cancelRequested = false
     this.inAgentLoop = false
